---
---
<section class="hero" id="hero" aria-labelledby="hero-heading">
  <!-- FONDO ESTRELLADO -->
  <div class="hero-bg" aria-hidden="true">
    <canvas id="starsCanvas"></canvas>
    <div class="hero-orb hero-orb--left"></div>
    <div class="hero-orb hero-orb--right"></div>
  </div>

  <!-- CONTENIDO PRINCIPAL: 2 columnas -->
  <div class="hero-inner wrap">
    <!-- COLUMNA IZQUIERDA: texto -->
    <div class="hero-text">
      <span class="hero-badge">• LOJA NUVEM — CLOUD GROWTH CONSULTANCY</span>
      <h1 id="hero-heading" class="hero-h1">
        Tu marca merece<br>
        <span class="grad-text">un sitio que lidera</span><br>
        el mundo.
      </h1>
      <p class="hero-sub">
        Vendemos las mejores páginas del mercado global y las mejores
        tiendas nube con todo integrado. Sitios de ultra-conversión
        en 72 horas — con el nivel visual que antes solo tenían
        las empresas más grandes del mundo.
      </p>

      <!-- MÉTRICAS EN FILA HORIZONTAL -->
      <div class="hero-metrics" role="list">
        <div class="metric" role="listitem">
          <span class="metric-num">24h</span>
          <span class="metric-label">Propuesta lista</span>
        </div>
        <div class="metric" role="listitem">
          <span class="metric-num">72h</span>
          <span class="metric-label">Sitio publicado</span>
        </div>
        <div class="metric" role="listitem">
          <span class="metric-num">98%</span>
          <span class="metric-label">Renuevan</span>
        </div>
        <div class="metric" role="listitem">
          <span class="metric-num">★ 5.0</span>
          <span class="metric-label">Rating</span>
        </div>
      </div>

      <!-- BOTONES -->
      <div class="hero-ctas">
        <a href="#contacto" class="btn btn-primary">Quiero mi sitio →</a>
        <a href="#servicios" class="btn btn-ghost">Ver cómo trabajamos ↓</a>
      </div>
    </div>

    <!-- COLUMNA DERECHA: logo NubeN con efectos de conversión -->
    <div class="hero-logo">
      <div class="lr lr1" aria-hidden="true"></div>
      <div class="lr lr2" aria-hidden="true"></div>
      <div class="lr lr3" aria-hidden="true"></div>
      <div class="logo-sweep" aria-hidden="true"></div>
      <img src="/logo.png" alt="NubeN — Cloud Growth" class="logo-media" width="560" height="480" loading="eager">
    </div>
  </div>
</section>


<style>
/* ═══ HERO COMPONENT STYLES (Industrial Premium) ══════════════════════════ */

.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  overflow: hidden;
  background: var(--primary-blue);
  padding: 120px 0 80px;
}

.hero-bg {
  position: absolute;
  top: 0; left: 0; width: 100%; height: 100%;
  z-index: 1; pointer-events: none;
}

#starsCanvas {
  position: absolute;
  top: 0; left: 0; width: 100%; height: 100%;
}

.hero-orb {
  position: absolute;
  width: 40vw;
  height: 40vw;
  filter: blur(120px);
  opacity: 0.15;
  border-radius: 50%;
  z-index: 2;
}

.hero-orb--left {
  top: -10%; left: -10%;
  background: var(--safety-orange);
}

.hero-orb--right {
  bottom: -10%; right: -10%;
  background: var(--industry-slate);
}

.hero-inner {
  position: relative;
  z-index: 10;
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  align-items: center;
  gap: 4rem;
}

.hero-h1 {
  font-size: clamp(40px, 5.5vw, 88px);
  font-weight: 800;
  color: #ffffff;
  line-height: 1.05;
  letter-spacing: -0.02em;
  margin-bottom: 1.5rem;
}

.hero-sub {
  font-size: 1.1rem;
  color: rgba(255,255,255,0.6);
  max-width: 540px;
  margin-bottom: 3rem;
  line-height: 1.6;
}

.hero-badge {
  display: inline-block;
  color: var(--safety-orange);
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.15em;
  margin-bottom: 1rem;
}

/* MÉTRICAS EN FILA HORIZONTAL */
.hero-metrics {
  display: flex;
  gap: 2rem;
  margin-bottom: 3.5rem;
}

.metric {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.metric-num {
  font-family: 'Syne', sans-serif;
  font-size: 24px;
  font-weight: 800;
  color: #fff;
}

.metric-label {
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: rgba(255,255,255,0.4);
}

.hero-ctas {
  display: flex;
  gap: 1.5rem;
}

/* LOGO Y EFECTOS */
.hero-logo {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-media {
  width: 100%;
  max-width: 520px;
  height: auto;
  filter: drop-shadow(0 0 80px rgba(249, 115, 22, 0.15));
  z-index: 10;
}

/* Efectos sonar */
.lr {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  border: 1px solid rgba(249, 115, 22, 0.2);
  width: 100%; height: 100%;
  animation: sonar 4s linear infinite;
  z-index: 1;
}

.lr2 { animation-delay: 1.33s; }
.lr3 { animation-delay: 2.66s; }

@keyframes sonar {
  0% { transform: translate(-50%, -50%) scale(0.6); opacity: 0; }
  20% { opacity: 0.6; }
  100% { transform: translate(-50%, -50%) scale(2.2); opacity: 0; }
}

@media (max-width: 1024px) {
  .hero-inner {
    grid-template-columns: 1fr;
    text-align: center;
  }
  .hero-inner > * { margin: 0 auto; }
  .hero-sub { margin: 0 auto 3rem; }
  .hero-metrics { justify-content: center; }
  .hero-ctas { justify-content: center; }
  .hero-logo { width: 80%; max-width: 400px; margin-top: 4rem; }
}

@media (max-width: 768px) {
  .hero-inner {
    flex-direction: column-reverse;
  }
}
</style>

<script>
  // Star Canvas Animation
  document.addEventListener('astro:page-load', () => {
    const canvas = document.getElementById('starsCanvas') as HTMLCanvasElement;
    if (canvas) {
      const ctx = canvas.getContext('2d');
      if (!ctx) return;
      
      let w: number, h: number, stars: any[] = [];
      
      const init = () => {
        w = canvas.width = window.innerWidth;
        h = canvas.height = window.innerHeight;
        stars = Array.from({length: 150}, () => ({
          x: Math.random() * w,
          y: Math.random() * h,
          size: Math.random() * 1.5,
          v: Math.random() * 0.5
        }));
      };

      const anim = () => {
        ctx.clearRect(0, 0, w, h);
        ctx.fillStyle = 'rgba(255, 255, 255, 0.5)';
        stars.forEach(s => {
          ctx.beginPath();
          ctx.arc(s.x, s.y, s.size, 0, Math.PI * 2);
          ctx.fill();
          s.y -= s.v;
          if (s.y < 0) s.y = h;
        });
        requestAnimationFrame(anim);
      };

      window.addEventListener('resize', init);
      init();
      anim();
    }

    // Hero Entry Animation (GSAP)
    // @ts-ignore
    gsap.from(".hero-text > *", {
      y: 30,
      opacity: 0,
      duration: 1,
      stagger: 0.15,
      ease: "power3.out",
      delay: 0.2
    });

    // @ts-ignore
    gsap.from(".hero-logo", {
      scale: 0.8,
      opacity: 0,
      duration: 1.5,
      ease: "expo.out",
      delay: 0.5
    });
  });
</script>
