---
import { NubeNHeroBg } from './NubeNHeroBg';

const {
  badge = "• NUEVA ERA DIGITAL",
  title = "Tu marca merece un sitio que",
  titleGrad = "lidera mercados.",
  subtitle = "Construimos ecosistemas digitales de ultra-conversión para empresas que buscan dominio digital. Estrategología y ejecución industrial en 72 horas.",
  ctaText = "Iniciar Protocolo →",
  ctaLink = "#contacto",
  secondaryCtaText = "Ver Auditoría ↓",
  secondaryCtaLink = "#proceso",
  logoSrc = "/nuben-logo.png",
} = Astro.props;
---

<section class="hero" id="inicio" aria-labelledby="hero-heading">
  <!-- BackgroundPaths Flotantes NubeN (React, client only) -->
  <div class="hero-bg" aria-hidden="true">
    <NubeNHeroBg client:only="react" />
    <div class="hero-orb hero-orb--cyan"></div>
    <div class="hero-orb hero-orb--purple"></div>
  </div>

  <div class="hero-inner wrap">
    <!-- COLUMNA TEXTO -->
    <div class="hero-text">
      <div class="hero-badge">
        <span class="hero-badge-dot"></span>
        {badge}
      </div>

      <h1 id="hero-heading" class="hero-h1">
        <span class="line-reveal">{title}</span><br>
        <span class="grad-text line-reveal">{titleGrad}</span>
      </h1>

      <p class="hero-sub line-reveal">{subtitle}</p>

      <div class="hero-ctas">
        <a href={ctaLink} class="btn btn-primary btn-mag" id="cta-main">{ctaText}</a>
        <a href={secondaryCtaLink} class="btn btn-ghost btn-mag" id="cta-secondary">{secondaryCtaText}</a>
      </div>

      <!-- MÉTRICAS ANIMADAS -->
      <div class="hero-metrics">
        <div class="hm-item">
          <span class="hm-val grad-text">24h</span>
          <span class="hm-label">Propuesta lista</span>
        </div>
        <div class="hm-item">
          <span class="hm-val grad-text" data-target="50" data-suffix="+">0+</span>
          <span class="hm-label">Proyectos</span>
        </div>
        <div class="hm-item">
          <span class="hm-val grad-text" data-target="98" data-suffix="%">0%</span>
          <span class="hm-label">Renuevan</span>
        </div>
        <div class="hm-item">
          <span class="hm-val grad-text">★5</span>
          <span class="hm-label">Rating</span>
        </div>
      </div>
    </div>

    <!-- COLUMNA LOGO 3D -->
    <div class="hero-visual" id="hero-logo-wrap">
      <div class="logo-container-3d" id="logo-3d">
        <!-- 3 Anillos Orbitales (CSS — 9s, 13s, 17s) -->
        <div class="orbit ring-1"></div>
        <div class="orbit ring-2"></div>
        <div class="orbit ring-3"></div>
        
        <!-- Core con Glow Pulsante -->
        <div class="logo-core">
          <div class="logo-glow"></div>
          <img
            src={logoSrc}
            alt="NubeN — Cloud Growth Consultancy"
            class="logo-img-3d"
            width="500" height="500"
            loading="eager"
            fetchpriority="high"
          />
          <!-- Partículas SVG en el símbolo infinito -->
          <svg class="logo-particles" viewBox="0 0 200 200" aria-hidden="true">
            <circle r="3" fill="#06B6D4" opacity="0.8">
              <animateMotion dur="6s" repeatCount="indefinite"
                path="M100,100 C60,60 40,80 60,100 C80,120 120,120 140,100 C160,80 140,60 100,100Z" />
            </circle>
            <circle r="2" fill="#8B5CF6" opacity="0.6">
              <animateMotion dur="9s" repeatCount="indefinite" begin="3s"
                path="M100,100 C140,60 160,80 140,100 C120,120 80,120 60,100 C40,80 60,60 100,100Z" />
            </circle>
            <circle r="2.5" fill="#06B6D4" opacity="0.5">
              <animateMotion dur="12s" repeatCount="indefinite" begin="1.5s"
                path="M100,100 C60,60 40,80 60,100 C80,120 120,120 140,100 C160,80 140,60 100,100Z" />
            </circle>
          </svg>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
/* ─── HERO ─── */
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  background: #020818;
  overflow: hidden;
  padding-top: 80px;
}

.hero-bg {
  position: absolute;
  top: 0; left: 0; width: 100%; height: 100%;
  z-index: 1; pointer-events: none;
}

.hero-orb {
  position: absolute;
  width: 60vw; height: 60vw;
  filter: blur(120px);
  border-radius: 50%;
  opacity: 0.12;
  transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
}
.hero-orb--cyan  { top: -10%;    left: -10%;  background: #06B6D4; }
.hero-orb--purple { bottom: -10%; right: -10%; background: #8B5CF6; }

.hero-inner {
  position: relative;
  z-index: 10;
  display: grid;
  grid-template-columns: 1.2fr 0.8fr;
  align-items: center;
  gap: 4rem;
}

/* ─── BADGE ─── */
.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #06B6D4;
  background: rgba(6,182,212,0.08);
  border: 1px solid rgba(6,182,212,0.25);
  border-radius: 999px;
  padding: 6px 18px;
  margin-bottom: 2rem;
}
.hero-badge-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: #06B6D4;
  animation: pulseDot 1.8s ease-in-out infinite;
}
@keyframes pulseDot {
  0%,100% { box-shadow: 0 0 0 0 rgba(6,182,212,0.5); }
  50%      { box-shadow: 0 0 0 6px rgba(6,182,212,0); }
}

/* ─── H1 ─── */
.hero-h1 {
  font-size: clamp(44px, 6vw, 92px);
  margin-bottom: 2rem;
  line-height: 0.95;
  color: #fff;
}

.hero-sub {
  font-size: 1.15rem;
  color: rgba(255,255,255,0.55);
  max-width: 560px;
  margin-bottom: 3rem;
  line-height: 1.65;
}

/* ─── CTAs ─── */
.hero-ctas {
  display: flex;
  gap: 1.25rem;
  flex-wrap: wrap;
  margin-bottom: 3rem;
}

/* ─── METRICS ─── */
.hero-metrics {
  display: grid;
  grid-template-columns: repeat(4, auto);
  gap: 2rem;
}
.hm-item { display: flex; flex-direction: column; gap: 4px; }
.hm-val {
  font-family: 'Syne', sans-serif;
  font-size: 2rem;
  font-weight: 800;
  line-height: 1;
}
.hm-label {
  font-size: 0.72rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: rgba(255,255,255,0.4);
}

/* ─── LOGO 3D ─── */
.hero-visual {
  display: flex;
  justify-content: center;
  perspective: 900px;
}
.logo-container-3d {
  position: relative;
  width: 100%;
  max-width: 480px;
  aspect-ratio: 1;
  transform-style: preserve-3d;
  animation: logoFloat 7s ease-in-out infinite;
  cursor: pointer;
  transition: transform 0.3s ease;
}
.logo-container-3d:hover {
  animation-play-state: paused;
  transform: scale(1.08) rotateY(360deg) !important;
  transition: transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
}

@keyframes logoFloat {
  0%   { transform: rotateX(4deg)   rotateY(-4deg)  translateY(0px); }
  33%  { transform: rotateX(-3deg)  rotateY(6deg)   translateY(-12px); }
  66%  { transform: rotateX(6deg)   rotateY(-2deg)  translateY(-6px); }
  100% { transform: rotateX(4deg)   rotateY(-4deg)  translateY(0px); }
}

.logo-core {
  position: relative;
  width: 100%; height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  transform-style: preserve-3d;
  z-index: 5;
}

.logo-img-3d {
  width: 90%;
  height: auto;
  filter: drop-shadow(0 0 45px rgba(6,182,212,0.45)) 
          drop-shadow(0 0 85px rgba(139,92,246,0.35));
  z-index: 10;
  position: relative;
  /* El brillo interno del logo se verá más saturado */
  filter: brightness(1.15) contrast(1.1) saturate(1.2);
}

.logo-glow {
  position: absolute;
  width: 90%; height: 90%;
  background: radial-gradient(circle, 
    rgba(6,182,212,0.6) 0%, 
    rgba(139,92,246,0.4) 40%, 
    transparent 85%
  );
  opacity: 0.5;
  filter: blur(65px);
  animation: glowPulse 4s ease-in-out infinite alternate;
  z-index: 1;
}

/* Backlight Aura */
.logo-container-3d::before {
  content: '';
  position: absolute;
  inset: -20%;
  background: radial-gradient(circle at center, rgba(6,182,212,0.15) 0%, transparent 70%);
  border-radius: 50%;
  z-index: -1;
  filter: blur(100px);
}
@keyframes glowPulse {
  from { opacity: 0.2; transform: scale(0.95); }
  to   { opacity: 0.5; transform: scale(1.15); }
}

/* Partículas */
.logo-particles {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 15;
  pointer-events: none;
}

/* Anillos Orbitales */
.orbit {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  transform-style: preserve-3d;
}
.ring-1 {
  width: 108%; height: 108%;
  border: 1px solid rgba(6,182,212,0.2);
  animation: rotateOrbit 9s  linear infinite;
}
.ring-2 {
  width: 130%; height: 130%;
  border: 1px solid rgba(139,92,246,0.15);
  animation: rotateOrbit 13s linear infinite reverse;
}
.ring-3 {
  width: 155%; height: 155%;
  border: 1px solid rgba(6,182,212,0.07);
  animation: rotateOrbit 17s linear infinite;
}
@keyframes rotateOrbit {
  from { transform: translate(-50%, -50%) rotateX(60deg) rotateZ(0deg); }
  to   { transform: translate(-50%, -50%) rotateX(60deg) rotateZ(360deg); }
}

/* ─── RESPONSIVE ─── */
@media (max-width: 1024px) {
  .hero-inner {
    grid-template-columns: 1fr;
    text-align: center;
    padding: 60px 0;
  }
  .hero-inner > * { margin: 0 auto; }
  .hero-sub, .hero-ctas { margin-inline: auto; }
  .hero-ctas { justify-content: center; }
  .hero-visual { order: -1; margin-bottom: 3rem; width: 65%; }
  .hero-metrics { grid-template-columns: repeat(2, 1fr); justify-items: center; }
}

@media (max-width: 768px) {
  .hero-visual { width: 200px; }
  .hero-metrics { grid-template-columns: repeat(2, 1fr); gap: 1rem; }
  .hero-ctas { flex-direction: column; align-items: center; }
}
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    // 1. Kinetic Typography (GSAP)
    // @ts-ignore
    const tl = gsap.timeline({ defaults: { ease: "expo.out", duration: 1.2 } });
    tl.from(".hero-badge",   { y: 30, opacity: 0, scale: 0.8, duration: 0.8 })
      .from(".line-reveal",  { y: 80, opacity: 0, stagger: 0.12, skewY: 4, duration: 1.4, clearProps: "all" }, "-=0.6")
      .from(".hero-ctas .btn", { y: 20, opacity: 0, stagger: 0.1, duration: 0.8 }, "-=0.9")
      .from(".hm-item", { y: 20, opacity: 0, stagger: 0.08, duration: 0.7 }, "-=0.8");

    // 2. Metric counters
    document.querySelectorAll('.hm-val[data-target]').forEach(el => {
      const target = parseInt(el.getAttribute('data-target') || '0');
      const suffix = el.getAttribute('data-suffix') || '';
      const obj = { val: 0 };
      // @ts-ignore
      gsap.to(obj, {
        val: target,
        duration: 2,
        ease: 'power2.out',
        scrollTrigger: { trigger: el, start: 'top 90%' },
        onUpdate: () => { el.textContent = Math.floor(obj.val) + suffix; }
      });
    });

    // 3. Mouse Parallax en logo
    const hero = document.getElementById('inicio');
    const logo3d = document.getElementById('logo-3d');
    const orbs = document.querySelectorAll('.hero-orb');

    hero?.addEventListener('mousemove', (e: MouseEvent) => {
      const x = (e.clientX / window.innerWidth  - 0.5) * 30;
      const y = (e.clientY / window.innerHeight - 0.5) * 30;
      // @ts-ignore
      gsap.to(logo3d, { rotationY: x, rotationX: -y, duration: 2, ease: 'power2.out' });
      orbs.forEach((o, i) => {
        // @ts-ignore
        gsap.to(o, { x: x * (i + 1) * 1.8, y: y * (i + 1) * 1.8, duration: 3, ease: 'power2.out' });
      });
    });
  });
</script>
