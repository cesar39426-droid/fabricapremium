---
interface Props {
  badge?: string;
  title?: string;
  titleGrad?: string;
  subtitle?: string;
  ctaText?: string;
  ctaLink?: string;
  secondaryCtaText?: string;
  secondaryCtaLink?: string;
  logoSrc?: string;
  metrics?: Array<{ num: string; label: string }>;
}

const {
  badge = "LOJA NUVEM — GROWTH PROTOCOL v4.0",
  title = "Escalamos tu empresa con",
  titleGrad = "Ingeniería Digital de Élite",
  subtitle = "No hacemos páginas. Construimos infraestructuras de conversión inmersivas que multiplican tu ROI operando 24/7.",
  ctaText = "Iniciar Auditoría Gratis →",
  ctaLink = "#contacto",
  secondaryCtaText = "Explorar Ecosistema ↓",
  secondaryCtaLink = "#servicios",
  logoSrc = "/nuben-logo.png",
  metrics = [
    { num: "24h", label: "Protocolo de Propuesta" },
    { num: "72h", label: "Time-to-Market" },
    { num: "98%", label: "Tasa de Retención" },
    { num: "60fps", label: "Performance Inmersiva" },
  ]
} = Astro.props;
---
<section class="hero" id="hero" aria-labelledby="hero-heading">
  <!-- FONDO ESTRELLADO -->
  <div class="hero-bg" aria-hidden="true">
    <canvas id="starsCanvas"></canvas>
    <div class="hero-orb hero-orb--left"></div>
    <div class="hero-orb hero-orb--right"></div>
  </div>

  <!-- CONTENIDO PRINCIPAL: 2 columnas -->
  <div class="hero-inner wrap">
    <!-- COLUMNA IZQUIERDA: texto -->
    <div class="hero-text">
      <span class="hero-badge" set:html={badge}></span>
      <h1 id="hero-heading" class="hero-h1">
        {title}<br>
        <span class="grad-text">{titleGrad}</span>
      </h1>
      <p class="hero-sub">
        {subtitle}
      </p>

      <!-- MÉTRICAS EN FILA HORIZONTAL -->
      <div class="hero-metrics" role="list">
        {metrics.map((m) => (
          <div class="metric" role="listitem">
            <span class="metric-num">{m.num}</span>
            <span class="metric-label">{m.label}</span>
          </div>
        ))}
      </div>

      <!-- BOTONES -->
      <div class="hero-ctas">
        <a href={ctaLink} class="btn btn-primary">{ctaText}</a>
        <a href={secondaryCtaLink} class="btn btn-ghost">{secondaryCtaText}</a>
      </div>
    </div>

    <!-- COLUMNA DERECHA: logo con efectos -->
    <div class="hero-logo">
      <div class="lr lr1" aria-hidden="true"></div>
      <div class="lr lr2" aria-hidden="true"></div>
      <div class="lr lr3" aria-hidden="true"></div>
      <div class="logo-sweep" aria-hidden="true"></div>
      <img src={logoSrc} alt="Brand Identity" class="logo-media" width="560" height="480" loading="eager">
    </div>
  </div>
</section>


<style>
/* ═══ HERO COMPONENT STYLES (Industrial Premium) ══════════════════════════ */

.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  overflow: hidden;
  background: var(--dark);
  padding: 140px 0 100px;
  perspective: 1500px;
}

.hero-bg {
  position: absolute;
  top: 0; left: 0; width: 100%; height: 100%;
  z-index: 1; pointer-events: none;
  transform: translateZ(-100px) scale(1.2);
}

#starsCanvas {
  position: absolute;
  top: 0; left: 0; width: 100%; height: 100%;
  opacity: 0.4;
}

.hero-orb {
  position: absolute;
  width: 50vw;
  height: 50vw;
  filter: blur(140px);
  opacity: 0.18;
  border-radius: 50%;
  z-index: 2;
}

.hero-orb--left {
  top: -15%; left: -10%;
  background: radial-gradient(circle, var(--nuben-accent), transparent);
}

.hero-orb--right {
  bottom: -15%; right: -10%;
  background: radial-gradient(circle, var(--cyan-accent), transparent);
}

.hero-inner {
  position: relative;
  z-index: 10;
  display: grid;
  grid-template-columns: 1.3fr 0.7fr;
  align-items: center;
  gap: 2rem;
  transform-style: preserve-3d;
}

.hero-text {
  transform: translateZ(50px);
}

.hero-h1 {
  font-size: clamp(48px, 7vw, 110px);
  font-weight: 800;
  color: #ffffff;
  line-height: 0.95;
  letter-spacing: -0.05em;
  margin-bottom: 2rem;
}

.hero-sub {
  font-size: 1.25rem;
  color: rgba(255,255,255,0.5);
  max-width: 600px;
  margin-bottom: 3.5rem;
  line-height: 1.5;
  font-weight: 400;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(249, 115, 22, 0.1);
  border: 1px solid rgba(249, 115, 22, 0.2);
  color: var(--nuben-accent);
  font-size: 11px;
  font-weight: 900;
  letter-spacing: 0.2em;
  padding: 8px 16px;
  border-radius: 4px;
  margin-bottom: 1.5rem;
  text-transform: uppercase;
}

.hero-metrics {
  display: flex;
  gap: 3rem;
  margin-bottom: 4rem;
}

.metric {
  display: flex;
  flex-direction: column;
}

.metric-num {
  font-family: 'Syne', sans-serif;
  font-size: 32px;
  font-weight: 800;
  color: #fff;
  letter-spacing: -0.05em;
}

.metric-label {
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  color: var(--nuben-accent);
  font-weight: 800;
}

.hero-logo {
  position: relative;
  transform: translateZ(120px) rotateY(-10deg);
  display: flex;
  justify-content: flex-end;
}

.logo-media {
  width: 110%;
  max-width: 600px;
  height: auto;
  filter: drop-shadow(0 0 100px rgba(249, 115, 22, 0.2));
}

.lr {
  border-color: rgba(249, 115, 22, 0.15);
}

@media (max-width: 1024px) {
  .hero-inner {
    grid-template-columns: 1fr;
    text-align: center;
  }
  .hero-inner > * { margin: 0 auto; }
  .hero-h1 { margin-inline: auto; }
  .hero-sub { margin: 0 auto 3.5rem; }
  .hero-metrics { justify-content: center; gap: 1.5rem; }
  .hero-logo { 
    transform: translateZ(50px) rotateY(0);
    order: -1;
    margin-bottom: 3rem;
  }
}

@media (max-width: 768px) {
  .hero-inner {
    flex-direction: column-reverse;
  }
}
</style>

<script>
  // Star Canvas Animation
  document.addEventListener('astro:page-load', () => {
    const canvas = document.getElementById('starsCanvas') as HTMLCanvasElement;
    if (canvas) {
      const ctx = canvas.getContext('2d');
      if (!ctx) return;
      
      let w: number, h: number, stars: any[] = [];
      
      const init = () => {
        w = canvas.width = window.innerWidth;
        h = canvas.height = window.innerHeight;
        stars = Array.from({length: 150}, () => ({
          x: Math.random() * w,
          y: Math.random() * h,
          size: Math.random() * 1.5,
          v: Math.random() * 0.5
        }));
      };

      const anim = () => {
        ctx.clearRect(0, 0, w, h);
        ctx.fillStyle = 'rgba(255, 255, 255, 0.5)';
        stars.forEach(s => {
          ctx.beginPath();
          ctx.arc(s.x, s.y, s.size, 0, Math.PI * 2);
          ctx.fill();
          s.y -= s.v;
          if (s.y < 0) s.y = h;
        });
        requestAnimationFrame(anim);
      };

      window.addEventListener('resize', init);
      init();
      anim();
    }

    // Hero Entry Animation (GSAP)
    // @ts-ignore
    gsap.from(".hero-text > *", {
      y: 30,
      opacity: 0,
      duration: 1,
      stagger: 0.15,
      ease: "power3.out",
      delay: 0.2
    });

    // @ts-ignore
    gsap.from(".hero-logo", {
      scale: 0.8,
      opacity: 0,
      duration: 1.5,
      ease: "expo.out",
      delay: 0.5
    });
  });
</script>
