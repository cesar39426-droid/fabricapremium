---
const {
  badge = "• NUEVA ERA DIGITAL",
  title = "Tu marca merece un sitio que",
  titleGrad = "lidera el mundo.",
  subtitle = "Construimos ecosistemas digitales de ultra-conversión. Diseño de alto impacto en 72 horas.",
  ctaText = "Quiero mi sitio →",
  ctaLink = "#contacto",
  secondaryCtaText = "Ver Proyectos ↓",
  secondaryCtaLink = "#resultados",
  logoSrc = "/nuben-logo.png",
} = Astro.props;
---
<section class="hero" id="hero" aria-labelledby="hero-heading">
  <!-- INTERACTIVE WEBGL SHADER BACKGROUND SIMULATION -->
  <div class="hero-bg" aria-hidden="true">
    <div id="shader-canvas"></div>
    <div class="hero-orb hero-orb--cyan"></div>
    <div class="hero-orb hero-orb--purple"></div>
  </div>

  <div class="hero-inner wrap">
    <div class="hero-text">
      <div class="hero-badge" set:html={badge}></div>
      <h1 id="hero-heading" class="hero-h1">
        <span class="line-reveal">{title}</span><br>
        <span class="grad-text line-reveal">{titleGrad}</span>
      </h1>
      <p class="hero-sub line-reveal">
        {subtitle}
      </p>

      <div class="hero-ctas">
        <a href={ctaLink} class="btn btn-primary btn-mag">{ctaText}</a>
        <a href={secondaryCtaLink} class="btn btn-ghost btn-mag">{secondaryCtaText}</a>
      </div>
    </div>

    <!-- NUBEN MASTER LOGO 3D UNIT -->
    <div class="hero-visual">
      <div class="logo-container-3d">
        <!-- Orbital Rings -->
        <div class="orbit ring-1"></div>
        <div class="orbit ring-2"></div>
        <div class="orbit ring-3"></div>
        
        <!-- Main Logo Stage -->
        <div class="logo-core">
          <div class="logo-glow"></div>
          <img src={logoSrc} alt="NubeN Enterprise" class="logo-img-3d" width="500" height="500" loading="eager">
          <!-- Data Particles simulation -->
          <div class="particles-overlay"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  background: var(--dark);
  overflow: hidden;
  padding-top: 80px;
}

.hero-bg {
  position: absolute;
  top: 0; left: 0; width: 100%; height: 100%;
  z-index: 1; pointer-events: none;
}

#shader-canvas {
  position: absolute;
  top: 0; left: 0; width: 100%; height: 100%;
  background: radial-gradient(circle at 50% 50%, rgba(6, 182, 212, 0.05) 0%, transparent 70%);
}

.hero-orb {
  position: absolute;
  width: 60vw; height: 60vw;
  filter: blur(120px);
  border-radius: 50%;
  opacity: 0.12;
  transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
}

.hero-orb--cyan {
  top: -10%; left: -10%;
  background: var(--nuben-accent);
}

.hero-orb--purple {
  bottom: -10%; right: -10%;
  background: var(--purple-accent);
}

.hero-inner {
  position: relative;
  z-index: 10;
  display: grid;
  grid-template-columns: 1.2fr 0.8fr;
  align-items: center;
  gap: 4rem;
}

.hero-h1 {
  font-size: clamp(48px, 6.5vw, 100px);
  margin-bottom: 2rem;
  line-height: 0.95;
  color: #fff;
}

.hero-sub {
  font-size: 1.2rem;
  color: rgba(255,255,255,0.55);
  max-width: 580px;
  margin-bottom: 3.5rem;
  line-height: 1.6;
}

.hero-ctas {
  display: flex;
  gap: 1.5rem;
}

/* ─── NUBEN LOGO 3D UNIT ─── */
.hero-visual {
  display: flex;
  justify-content: center;
  perspective: 2000px;
}

.logo-container-3d {
  position: relative;
  width: 100%;
  max-width: 500px;
  aspect-ratio: 1;
  transform-style: preserve-3d;
}

.logo-core {
  position: relative;
  width: 100%; height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  transform-style: preserve-3d;
  z-index: 5;
}

.logo-img-3d {
  width: 85%;
  height: auto;
  filter: drop-shadow(0 0 50px rgba(6, 182, 212, 0.2));
  z-index: 10;
}

.logo-glow {
  position: absolute;
  width: 60%; height: 60%;
  background: radial-gradient(circle, var(--nuben-accent) 0%, transparent 70%);
  opacity: 0.3;
  filter: blur(40px);
  animation: glowPulse 4s ease-in-out infinite alternate;
}

@keyframes glowPulse {
  from { opacity: 0.2; transform: scale(1); }
  to { opacity: 0.4; transform: scale(1.2); }
}

.orbit {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  border: 1px solid rgba(255, 255, 255, 0.03);
  border-radius: 50%;
  transform-style: preserve-3d;
}

.ring-1 { width: 110%; height: 110%; border-color: rgba(6, 182, 212, 0.1); animation: rotateOrbit 12s linear infinite; }
.ring-2 { width: 130%; height: 130%; border-color: rgba(139, 92, 246, 0.1); animation: rotateOrbit 18s linear infinite reverse; }
.ring-3 { width: 150%; height: 150%; border-color: rgba(6, 182, 212, 0.05); animation: rotateOrbit 25s linear infinite; }

@keyframes rotateOrbit {
  from { transform: translate(-50%, -50%) rotateX(60deg) rotateZ(0deg); }
  to { transform: translate(-50%, -50%) rotateX(60deg) rotateZ(360deg); }
}

@media (max-width: 1024px) {
  .hero-inner {
    grid-template-columns: 1fr;
    text-align: center;
    padding: 60px 0;
  }
  .hero-inner > * { margin: 0 auto; }
  .hero-sub { margin-inline: auto; }
  .hero-ctas { justify-content: center; }
  .hero-visual { order: -1; margin-bottom: 4rem; width: 70%; }
}
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    // 1. Kinetic Typography (GSAP)
    // @ts-ignore
    const tl = gsap.timeline({ defaults: { ease: "expo.out", duration: 1.2 } });
    
    tl.from(".hero-badge", { y: 30, opacity: 0, scale: 0.8, duration: 1 })
      .from(".line-reveal", { 
        y: 80, 
        opacity: 0, 
        stagger: 0.1, 
        skewY: 5,
        duration: 1.4,
        clearProps: "all"
      }, "-=0.7")
      .from(".hero-ctas .btn", { 
        y: 20, 
        opacity: 0, 
        stagger: 0.1,
        duration: 0.8 
      }, "-=1");

    // 2. Parallax Mouse Move
    const hero = document.getElementById('hero');
    const container = document.querySelector('.logo-container-3d');
    const orbs = document.querySelectorAll('.hero-orb');

    hero?.addEventListener('mousemove', (e: MouseEvent) => {
      const { clientX, clientY } = e;
      const x = (clientX / window.innerWidth - 0.5) * 40;
      const y = (clientY / window.innerHeight - 0.5) * 40;
      
      // @ts-ignore
      gsap.to(container, {
        rotationY: x,
        rotationX: -y,
        duration: 2,
        ease: "power2.out"
      });

      orbs.forEach((orb, i) => {
        // @ts-ignore
        gsap.to(orb, {
          x: x * (i + 1) * 2,
          y: y * (i + 1) * 2,
          duration: 3,
          ease: "power2.out"
        });
      });
    });

    // 3. Magnetic Buttons
    document.querySelectorAll('.btn-mag').forEach(btn => {
      btn.addEventListener('mousemove', (e: any) => {
        const rect = btn.getBoundingClientRect();
        const dx = (e.clientX - rect.left - rect.width / 2) * 0.4;
        const dy = (e.clientY - rect.top - rect.height / 2) * 0.4;
        // @ts-ignore
        gsap.to(btn, { x: dx, y: dy, duration: 0.3 });
      });
      btn.addEventListener('mouseleave', () => {
        // @ts-ignore
        gsap.to(btn, { x: 0, y: 0, duration: 0.6, ease: "elastic.out(1, 0.4)" });
      });
    });
  });
</script>
