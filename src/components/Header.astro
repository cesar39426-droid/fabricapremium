---
---
<header id="site-header">
  <nav id="nav" role="navigation" aria-label="Navegación principal">
    <div class="wrap nav-in">
      <a href="#hero" class="cn-logo" aria-label="NubeN — Inicio">
        <img src="/nuben-logo.png" alt="NubeN" class="cn-logo-img" width="48" height="48" loading="eager">
        <div class="cn-logo-text">
          <span class="cn-brand">NubeN</span>
          <span class="cn-sub">Cloud Growth</span>
        </div>
      </a>
      <ul class="nav-links" role="list">
        <li><a href="#servicios">Servicios</a></li>
        <li><a href="#proceso">Proceso</a></li>
        <li><a href="#resultados">Resultados</a></li>
        <li><a href="#contacto">Contacto</a></li>
      </ul>
      <a href="#contacto" class="btn btn-primary nav-cta">Quiero mi sitio →</a>
    </div>
  </nav>
</header>

<style>
/* ─── CLOUD-GLASS NAVBAR 2026 (Industrial Edition) ─── */

:root {
  --nuben-accent: #F97316;
  --nuben-accent-rgb: 249, 115, 22;
}

#nav {
  position: fixed !important;
  top: 1.5rem;
  left: 50%;
  transform: translateX(-50%);
  width: 95%;
  max-width: 1200px;
  z-index: 9999;
  background: rgba(255, 255, 255, 0.02);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  backdrop-filter: blur(20px) saturate(180%);
  border: 1px solid rgba(255, 255, 255, 0.05);
  border-radius: 100px;
  transition: all 0.5s cubic-bezier(0.19, 1, 0.22, 1);
}

#nav.scrolled {
  top: 1rem;
  width: 90%;
  max-width: 1000px;
  background: rgba(5, 8, 16, 0.8) !important;
  border-color: rgba(249, 115, 22, 0.2) !important;
  box-shadow: 0 20px 40px rgba(0,0,0,0.4);
}

.nav-in {
  display: flex !important;
  align-items: center;
  justify-content: space-between;
  padding: 0.6rem 2rem;
}

.cn-logo {
  display: flex;
  align-items: center;
  gap: 14px;
  text-decoration: none;
}

.cn-logo-img { 
  transition: transform 0.5s ease;
}

.cn-logo:hover .cn-logo-img {
  transform: rotate(10deg) scale(1.1);
}

.cn-brand {
  font-family: 'Syne', sans-serif;
  font-weight: 800; font-size: 1.4rem;
  color: #fff; letter-spacing: -0.04em;
}

.cn-sub {
  font-size: 9px;
  text-transform: uppercase;
  letter-spacing: 0.2em;
  color: var(--nuben-accent);
  font-weight: 800;
  display: block;
}

.nav-links {
  display: flex; gap: 2.5rem; list-style: none;
}

.nav-links a {
  color: rgba(255,255,255,0.5) !important;
  text-decoration: none; font-size: 0.9rem; font-weight: 700;
  transition: all 0.3s;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.nav-links a:hover { 
  color: #fff !important; 
  text-shadow: 0 0 15px rgba(255,255,255,0.5);
}

.nav-cta {
  padding: 10px 24px !important;
  font-size: 0.75rem !important;
}

@media (max-width: 768px) {
  #nav { top: 1rem; width: 92%; }
  .nav-links { display: none; }
}
</style>

<script>
  // Script para el estado scrolled del navbar
  document.addEventListener('astro:page-load', () => {
    const nav = document.getElementById('nav');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        nav?.classList.add('scrolled');
      } else {
        nav?.classList.remove('scrolled');
      }
    });
  });
</script>
