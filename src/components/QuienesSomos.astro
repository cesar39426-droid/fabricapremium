---
interface Props {
  badge?: string;
  title?: string;
  titleGrad?: string;
  body?: string;
  pillars?: Array<{ icon: string; title: string; desc: string }>;
  statNum?: string;
  statLabel?: string;
  logoSrc?: string;
}

const {
  badge = "Quiénes somos",
  title = "No somos una agencia.",
  titleGrad = "Somos un sistema.",
  body = "Somos una fábrica de desarrollo web impulsada por inteligencia artificial.",
  pillars = [
    { icon: "⚡", title: "Sistema, no agencia", desc: "Propuesta en 24h. Sitio publicado en 72h." },
    { icon: "🏪", title: "Diseño único", desc: "Sin templates genéricos. Estratégicamente único." },
    { icon: "📈", title: "Resultados", desc: "Tu sitio es tu vendedor más poderoso, 24/7." }
  ],
  statNum = "72h",
  statLabel = "de propuesta a sitio publicado",
  logoSrc = "/nuben-logo.png"
} = Astro.props;
---
<section id="quienes-somos" class="sec sec-alt">
  <div class="wrap qs-grid">

    <!-- COLUMNA TEXTO -->
    <div class="qs-text">
      <div class="label-pill">{badge}</div>
      <h2 class="sec-title">
        {title}<br>
        <span class="grad-text">{titleGrad}</span>
      </h2>
      <p class="qs-body">
        {body}
      </p>
      <div class="qs-pillars">
        {pillars.map((p) => (
          <div class="qp">
            <div class="qp-icon">{p.icon}</div>
            <div>
              <strong>{p.title}</strong>
              <p>{p.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- COLUMNA VISUAL: logo animado -->
    <div class="qs-visual">
      <div class="logo-stage qs-logo-stage">
        <div class="lr lr1" aria-hidden="true"></div>
        <div class="lr lr2" aria-hidden="true"></div>
        <div class="lr lr3" aria-hidden="true"></div>
        <div class="logo-scene">
          <img src={logoSrc} alt="Brand"
               class="logo-media" width="320" height="280" loading="lazy">
        </div>
      </div>
      <!-- Stat card -->
      <div class="qs-stat-card">
        <div class="qs-stat-num grad-text">{statNum}</div>
        <div class="qs-stat-lbl" set:html={statLabel}></div>
      </div>
    </div>

  </div>
</section>

<style>
  .qs-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 4rem;
    align-items: center;
  }

  .qs-body {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.7;
    margin-bottom: 3rem;
  }

  .qs-pillars {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .qp {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .qp-icon {
    width: 48px;
    height: 48px;
    background: rgba(249, 115, 22, 0.1);
    border: 1px solid rgba(249, 115, 22, 0.2);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .qp strong {
    display: block;
    font-size: 1.1rem;
    margin-bottom: 0.25rem;
  }

  .qp p {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.5);
    margin: 0;
  }

  .qs-visual {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .qs-logo-stage {
    position: relative;
    width: 320px;
    height: 320px;
  }

  .qs-stat-card {
    position: absolute;
    bottom: -20px;
    right: -20px;
    background: rgba(15, 23, 42, 0.8);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.1);
    padding: 24px;
    border-radius: 20px;
    text-align: center;
    box-shadow: 0 20px 40px rgba(0,0,0,0.3);
  }

  .qs-stat-num {
    font-size: 2.5rem;
    font-weight: 800;
    line-height: 1;
    margin-bottom: 8px;
  }

  .qs-stat-lbl {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: rgba(255,255,255,0.5);
  }

  @media (max-width: 1024px) {
    .qs-grid {
      grid-template-columns: 1fr;
      gap: 5rem;
    }
    .qs-text { text-align: center; }
    .qs-pillars { align-items: center; }
    .qp { text-align: left; max-width: 400px; }
    .qs-stat-card { right: 50%; transform: translateX(50%); }
  }
</style>
