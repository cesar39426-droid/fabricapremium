---
interface Props {
  color?: string;
  nextSectionId?: string;
}

const { color = "#050810", nextSectionId = "#innovation" } = Astro.props;
---

<div class="mask-divider-container">
  <svg class="mask-svg" viewBox="0 0 100 100" preserveAspectRatio="none">
    <defs>
      <clipPath id="sectionMask" clipPathUnits="objectBoundingBox">
        <path d="M 0,0 L 1,0 L 1,1 L 0,1 Z" id="maskPath" />
      </clipPath>
    </defs>
  </svg>
</div>

<style>
  .mask-divider-container {
    position: relative;
    width: 100%;
    height: 10vh; /* Zona de transición */
    background: transparent;
    pointer-events: none;
    z-index: 10;
  }
  
  .mask-svg {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
  }
</style>

<script>
  // Script para manejar la revelación inmersiva (Awwwards Style)
  document.addEventListener('astro:page-load', () => {
    // @ts-ignore
    gsap.registerPlugin(ScrollTrigger);

    // Animación de la máscara (Haciendo que la sección siguiente aparezca de forma fluida)
    // Nota: Esto se vincula a las transiciones de sección sugeridas en NotebookLM
    const maskPath = document.querySelector('#maskPath');
    
    if (maskPath) {
      // @ts-ignore
      gsap.to(maskPath, {
        scrollTrigger: {
          trigger: ".mask-divider-container",
          start: "top bottom",
          end: "bottom top",
          scrub: 1
        },
        attr: { d: "M 0,0 L 1,0 L 1,0 C 0.5,0.2 0.5,0.2 0,0 Z" }, // Efecto de cierre/curva
        ease: "none"
      });
    }
  });
</script>
