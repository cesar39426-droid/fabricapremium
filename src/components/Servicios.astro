---
interface Service {
  icon: string;
  label: string;
  title: string;
  description: string;
  detail: string;
  badge?: string;
  featured?: boolean;
}

interface Props {
  badge?: string;
  title?: string;
  titleGrad?: string;
  subtitle?: string;
  services?: Service[];
}

const {
  badge = "Servicios",
  title = "Todo lo que necesitás para",
  titleGrad = " crecer online",
  subtitle = "Desde la estrategia hasta la ejecución. Un equipo, resultados medibles.",
  services = [
    {
      icon: "🛒",
      label: "E-commerce",
      title: "Tiendas Nube Pro",
      description: "E-commerce inmersivos con optimización de conversión del 40%.",
      detail: "Integración total con MercadoPago, Logística y CRM. UX ultra-rápida diseñada para retener al usuario y maximizar el ticket promedio.",
      badge: "Best Seller",
      featured: true
    },
    {
      icon: "🌐",
      label: "Web Factory",
      title: "Landing Pages V4",
      description: "Páginas de aterrizaje inmersivas con JS de 60fps.",
      detail: "Construidas con Astro + GSAP. Carga instantánea (< 1s) y animaciones de 'living presence' que transmiten autoridad de marca."
    },
    {
      icon: "🔍",
      label: "SEO Authority",
      title: "Visibilidad Industrial",
      description: "Dominio de búsquedas locales y nacionales en Google.",
      detail: "Estrategia de contenidos impulsada por IA y optimización técnica para aparecer en el top 3 de los nichos comerciales más competitivos."
    },
    {
      icon: "⚡",
      label: "Automation",
      title: "Vendedores IA 24/7",
      description: "Agentes inteligentes que cierran ventas mientras dormís.",
      detail: "Chatbots con LLMs personalizados que entienden tu negocio, califican leads y agendan citas automáticamente en tu CRM."
    },
    {
      icon: "🖥️",
      label: "Sistemas",
      title: "Gestión & CRM",
      description: "Automatización de procesos internos para PyMEs.",
      detail: "Digitalización de flujos con Bitrix24 y soluciones Custom. Centralizamos tu operación para que el crecimiento no sea un caos."
    },
    {
      icon: "🎨",
      label: "Branding",
      title: "Identidad Inmersiva",
      description: "Diseño que eleva el valor percibido de tu empresa.",
      detail: "Consistencia visual, storytelling estratégico y assets digitales de clase mundial para diferenciarte de la competencia tradicional."
    }
  ],
} = Astro.props;
---

<section id="servicios" class="sec" aria-labelledby="servicios-title">
  <div class="wrap">
    <div class="sec-head-svc">
      <div class="label-pill">{badge}</div>
      <h2 class="sec-title" id="servicios-title">
        {title}
        <span class="grad-text">{titleGrad}</span>
      </h2>
      <p class="sec-sub-svc">{subtitle}</p>
    </div>

    <div class="bento-grid">
      {services.map((s, i) => (
        <article
          class={`bc-card${s.featured ? ' bc-featured' : ''}`}
          data-index={i}
          role="button"
          tabindex="0"
          aria-expanded="false"
        >
          <span class="bc-lbl">{s.label}</span>
          <div class="bc-icon-wrap">{s.icon}</div>
          <h3 class="bc-title">{s.title}</h3>
          <p class="bc-desc">{s.description}</p>
          <p class="bc-detail">{s.detail}</p>
          {s.badge && <span class="bc-badge">{s.badge}</span>}
          <div class="bc-cta">Ver más <span class="bc-arrow">→</span></div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .sec-head-svc {
    text-align: center;
    max-width: 800px;
    margin: 0 auto 5rem;
  }

  .sec-sub-svc {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.6);
    margin-top: 1rem;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  .bc-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 24px;
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: all 0.45s cubic-bezier(0.16, 1, 0.3, 1);
    min-height: 340px;
  }

  .bc-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(249, 115, 22, 0.5);
    transform: translateY(-6px);
    box-shadow: 0 24px 48px rgba(0,0,0,0.4);
  }

  .bc-card.is-open {
    background: linear-gradient(135deg, rgba(15,23,42,0.98), rgba(249,115,22,0.1));
    border-color: var(--safety-orange);
    transform: scale(1.02);
  }

  .bc-featured {
    grid-column: span 2;
    background: rgba(255, 255, 255, 0.04);
    border-color: rgba(249, 115, 22, 0.2);
  }

  .bc-lbl {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--safety-orange);
  }

  .bc-icon-wrap {
    font-size: 2.2rem;
    line-height: 1;
    margin: 0.25rem 0;
  }

  .bc-title {
    font-size: 1.5rem;
    font-weight: 800;
    color: #fff;
    margin: 0;
  }

  .bc-desc {
    font-size: 0.95rem;
    color: rgba(255,255,255,0.55);
    line-height: 1.6;
    margin: 0;
    flex-grow: 1;
  }

  .bc-detail {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.75);
    line-height: 1.7;
    margin: 0;
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height 0.4s ease, opacity 0.4s ease;
  }

  .bc-card.is-open .bc-detail {
    max-height: 200px;
    opacity: 1;
  }

  .bc-card.is-open .bc-desc {
    display: none;
  }

  .bc-badge {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    background: var(--safety-orange);
    color: #000;
    font-size: 0.65rem;
    font-weight: 900;
    padding: 4px 12px;
    border-radius: 99px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .bc-cta {
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--safety-orange);
    margin-top: auto;
    padding-top: 1rem;
  }

  .bc-arrow {
    display: inline-block;
    transition: transform 0.3s;
  }
  .bc-card.is-open .bc-arrow {
    transform: rotate(90deg);
  }

  @media (max-width: 1024px) {
    .bento-grid { grid-template-columns: 1fr 1fr; }
    .bc-featured { grid-column: span 2; }
  }

  @media (max-width: 640px) {
    .bento-grid { grid-template-columns: 1fr; }
    .bc-featured { grid-column: span 1; }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll('.bc-card').forEach(card => {
      const toggle = () => {
        const isOpen = card.classList.toggle('is-open');
        card.setAttribute('aria-expanded', String(isOpen));
        const cta = card.querySelector('.bc-cta');
        if (cta) cta.innerHTML = isOpen ? 'Resumir <span class="bc-arrow">→</span>' : 'Ver más <span class="bc-arrow">→</span>';
      };
      card.addEventListener('click', toggle);
      card.addEventListener('keydown', (e: any) => { if (e.key === 'Enter' || e.key === ' ') toggle(); });
    });
  });
</script>
