import BentoGrid from "./BentoGrid.jsx";
---
<section id="servicios" class="sec" aria-labelledby="servicios-title">
  <div class="wrap">
    <div class="sec-head">
      <div class="label-pill">Servicios</div>
      <h2 class="sec-title" id="servicios-title">
        Todo lo que necesitás para
        <span class="grad-text"> crecer online</span>
      </h2>
      <p class="sec-sub">
        Desde la estrategia hasta la ejecución. Un equipo, resultados medibles.
      </p>
    </div>

    <BentoGrid client:visible />
  </div>
</section>

<style is:global>
  /* Base styles for the React BentoGrid */
  .bento {
    display: grid;
    grid-template-columns: repeat(3, 1fr) !important;
    gap: 32px;
  }

  .bc {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 28px;
    padding: 3rem 2.5rem;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    user-select: none;
    display: flex;
    flex-direction: column;
    min-height: 380px;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .bc:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: var(--safety-orange);
    box-shadow: 0 30px 60px rgba(0,0,0,0.5);
    transform: translateY(-8px);
  }

  .bc-active {
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.95), rgba(249, 115, 22, 0.15)) !important;
    border-color: var(--safety-orange) !important;
    transform: scale(1.02);
  }

  .bc-feat {
    grid-column: span 2;
    background: rgba(255, 255, 255, 0.04);
  }

  .bc-icon { font-size: 2.5rem; margin-bottom: 1.5rem; }
  .bc-t { font-size: 1.6rem; font-weight: 800; margin-bottom: 1rem; color: #fff; }
  .bc-d { font-size: 1rem; color: rgba(255,255,255,0.6); line-height: 1.6; flex-grow: 1; }
  .bc-action { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; color: var(--safety-orange); margin-top: 2rem; }
  .bc-badge { position: absolute; top: 1.5rem; right: 1.5rem; background: var(--safety-orange); color: #000; font-size: 10px; font-weight: 900; padding: 4px 12px; border-radius: 99px; }

  @media (max-width: 1024px) { .bento { grid-template-columns: 1fr 1fr !important; } .bc-feat { grid-column: span 2; } }
  @media (max-width: 768px) { .bento { grid-template-columns: 1fr !important; } .bc-feat { grid-column: span 1; } }
</style>

<style>
  .sec-head {
    text-align: center;
    max-width: 800px;
    margin: 0 auto 5rem;
  }

  .sec-sub {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.6);
    margin-top: 1rem;
  }

  .bento {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: repeat(2, auto);
    gap: 24px;
  }

  .bc {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 24px;
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    overflow: hidden;
  }

  .bc:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: var(--safety-orange);
    transform: translateY(-5px);
  }

  .bc-feat {
    grid-column: span 2;
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.9), rgba(51, 65, 85, 0.4));
    border-color: rgba(249, 115, 22, 0.3);
  }

  .bc-icon {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .bc-lbl {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--safety-orange);
    font-weight: 700;
  }

  .bc-t {
    font-size: 1.5rem;
    font-weight: 800;
    margin: 0;
    color: #fff;
  }

  .bc-d {
    font-size: 0.95rem;
    color: rgba(255,255,255,0.5);
    line-height: 1.6;
    margin: 0;
  }

  .bc-badge {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    background: var(--safety-orange);
    color: #000;
    font-size: 0.7rem;
    font-weight: 800;
    padding: 4px 12px;
    border-radius: 99px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  @media (max-width: 1024px) {
    .bento { grid-template-columns: 1fr 1fr; }
    .bc-feat { grid-column: span 2; }
  }

  @media (max-width: 768px) {
    .bento { grid-template-columns: 1fr; }
    .bc-feat { grid-column: span 1; }
    .bc { padding: 2rem; }
  }
</style>
