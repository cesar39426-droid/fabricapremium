---
---
<section class="relative w-full py-24 px-4 bg-[#0A101C] overflow-hidden">
  <div class="max-w-5xl mx-auto z-10 relative">
    
    <div class="mb-16 md:mb-24 text-center md:text-left filosofia-header">
      <h2 class="text-4xl md:text-6xl font-extrabold text-white font-syne leading-tight tracking-tight">
        No somos consultores.<br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#00C2FF] to-[#0A101C]">Somos constructores de sistemas.</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-16">
      
      <!-- Feature 1 -->
      <div class="filosofia-item flex gap-4">
        <div class="w-12 h-12 rounded-full bg-white/5 flex items-center justify-center shrink-0 border border-white/10 text-xl font-syne text-[#00C2FF]">1</div>
        <div>
          <h4 class="text-xl font-bold text-white mb-2 font-syne">Cero Jerga, 100% Negocios</h4>
          <p class="text-gray-400 font-dm-sans leading-relaxed">Hablamos en términos de ROI, leads y ticket promedio, no de servidores ni de líneas de código abstracto.</p>
        </div>
      </div>

      <!-- Feature 2 -->
      <div class="filosofia-item flex gap-4">
        <div class="w-12 h-12 rounded-full bg-white/5 flex items-center justify-center shrink-0 border border-white/10 text-xl font-syne text-[#00C2FF]">2</div>
        <div>
          <h4 class="text-xl font-bold text-white mb-2 font-syne">Soluciones Empaquetadas</h4>
          <p class="text-gray-400 font-dm-sans leading-relaxed">Entregamos un motor terminado, encendido y con las llaves puestas. Tu equipo solo tiene que acelerar y vender.</p>
        </div>
      </div>

      <!-- Feature 3 -->
      <div class="filosofia-item flex gap-4">
        <div class="w-12 h-12 rounded-full bg-white/5 flex items-center justify-center shrink-0 border border-white/10 text-xl font-syne text-[#00C2FF]">3</div>
        <div>
          <h4 class="text-xl font-bold text-white mb-2 font-syne">Fricción Cero</h4>
          <p class="text-gray-400 font-dm-sans leading-relaxed">Nos hacemos cargo de integrar cada pieza en el backend. Las conexiones, la IA y la infraestructura corren 100% por nuestra cuenta.</p>
        </div>
      </div>

      <!-- Feature 4 -->
      <div class="filosofia-item flex gap-4">
        <div class="w-12 h-12 rounded-full bg-white/5 flex items-center justify-center shrink-0 border border-white/10 text-xl font-syne text-[#00C2FF]">4</div>
        <div>
          <h4 class="text-xl font-bold text-white mb-2 font-syne">Escalabilidad por Diseño</h4>
          <p class="text-gray-400 font-dm-sans leading-relaxed">La base tecnológica que construimos hoy está preparada para soportar el volumen de transacciones que vas a tener en tres años.</p>
        </div>
      </div>

    </div>

    <!-- Quote -->
    <div class="mt-24 p-8 md:p-12 bg-gradient-to-br from-[#0F172A] to-[#0A101C] rounded-3xl border border-white/10 text-center relative overflow-hidden quote-box">
      <div class="absolute -top-10 -left-10 text-[150px] text-white/5 font-serif leading-none select-none">"</div>
      <p class="text-2xl md:text-3xl lg:text-4xl text-white font-syne font-bold leading-tight z-10 relative">
        "Empaquetamos la complejidad tecnológica para que vos solo <span class="text-[#00C2FF]">operes y crezcas</span>."
      </p>
    </div>

  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  
  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('astro:page-load', () => {
    gsap.fromTo('.filosofia-header',
      { opacity: 0, x: -50 },
      { opacity: 1, x: 0, duration: 1, ease: 'power3.out', scrollTrigger: { trigger: '.filosofia-header', start: 'top 80%' } }
    );

    gsap.fromTo('.filosofia-item',
      { opacity: 0, y: 30 },
      { opacity: 1, y: 0, duration: 0.8, stagger: 0.2, ease: 'power3.out', scrollTrigger: { trigger: '.filosofia-item', start: 'top 85%' } }
    );

    gsap.fromTo('.quote-box',
      { opacity: 0, scale: 0.95 },
      { opacity: 1, scale: 1, duration: 1, ease: 'back.out(1.7)', scrollTrigger: { trigger: '.quote-box', start: 'top 80%' } }
    );
  });
</script>
