---
---
<section id="soluciones" class="relative w-full py-24 px-4 bg-[#050810]">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16 soluciones-header">
      <h2 class="text-4xl md:text-5xl font-extrabold text-white font-syne mb-4">La Fábrica Digital</h2>
      <p class="text-xl text-gray-400 font-dm-sans max-w-2xl mx-auto">Ecosistemas listos para operar que transforman procesos manuales en flujos de ingresos escalables.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      
      <!-- Solución 1 -->
      <div class="solucion-card group relative p-8 rounded-3xl bg-[#0F172A]/50 border border-white/5 backdrop-blur-xl hover:border-[#00C2FF]/30 transition-colors duration-500 overflow-hidden flex flex-col h-full">
        <div class="absolute -top-20 -right-20 w-40 h-40 bg-[#00C2FF] opacity-0 group-hover:opacity-10 blur-[60px] rounded-full transition-opacity duration-500"></div>
        
        <div class="w-12 h-12 bg-[#00C2FF]/10 rounded-2xl flex items-center justify-center mb-6 text-[#00C2FF] group-hover:scale-110 transition-transform duration-500">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
        </div>
        
        <h3 class="text-2xl font-bold text-white font-syne mb-3">Ecosistemas E-commerce</h3>
        <p class="text-gray-400 mb-6 text-sm flex-grow">Tiendas rápidas e integradas que transforman la inversión publicitaria en facturación real.</p>
        
        <ul class="space-y-3 mb-8">
          <li class="flex items-start text-sm text-gray-300">
            <svg class="w-5 h-5 text-[#00C2FF] mr-2 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            Despliegue industrial sobre plataformas sólidas.
          </li>
          <li class="flex items-start text-sm text-gray-300">
            <svg class="w-5 h-5 text-[#00C2FF] mr-2 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            Arquitectura orientada a conversión y velocidad.
          </li>
          <li class="flex items-start text-sm text-gray-300">
            <svg class="w-5 h-5 text-[#00C2FF] mr-2 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            Sincronización automática de inventario.
          </li>
        </ul>
        
        <a href="#onboarding" class="text-[#00C2FF] font-medium text-sm flex items-center hover:text-white transition-colors mt-auto">
          Explorá nuestros ecosistemas <span class="ml-2 group-hover:translate-x-1 transition-transform">→</span>
        </a>
      </div>

      <!-- Solución 2 -->
      <div class="solucion-card group relative p-8 rounded-3xl bg-[#0F172A]/50 border border-white/5 backdrop-blur-xl hover:border-[#F97316]/30 transition-colors duration-500 overflow-hidden flex flex-col h-full transform md:-translate-y-4">
        <div class="absolute -top-20 -right-20 w-40 h-40 bg-[#F97316] opacity-0 group-hover:opacity-10 blur-[60px] rounded-full transition-opacity duration-500"></div>
        
        <div class="w-12 h-12 bg-[#F97316]/10 rounded-2xl flex items-center justify-center mb-6 text-[#F97316] group-hover:scale-110 transition-transform duration-500">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        </div>
        
        <h3 class="text-2xl font-bold text-white font-syne mb-3">Automatización e IA</h3>
        <p class="text-gray-400 mb-6 text-sm flex-grow">Agentes de software que trabajan 24/7 eliminando las tareas manuales de tu operación.</p>
        
        <ul class="space-y-3 mb-8">
          <li class="flex items-start text-sm text-gray-300">
            <svg class="w-5 h-5 text-[#F97316] mr-2 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            Calificación de leads en tiempo real vía WhatsApp.
          </li>
          <li class="flex items-start text-sm text-gray-300">
            <svg class="w-5 h-5 text-[#F97316] mr-2 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            Conexión invisible entre CRMs y prospectos.
          </li>
          <li class="flex items-start text-sm text-gray-300">
            <svg class="w-5 h-5 text-[#F97316] mr-2 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            Reducción drástica del trabajo operativo.
          </li>
        </ul>
        
        <a href="#onboarding" class="text-[#F97316] font-medium text-sm flex items-center hover:text-white transition-colors mt-auto">
          Optimizá tu operación hoy <span class="ml-2 group-hover:translate-x-1 transition-transform">→</span>
        </a>
      </div>

      <!-- Solución 3 -->
      <div class="solucion-card group relative p-8 rounded-3xl bg-[#0F172A]/50 border border-white/5 backdrop-blur-xl hover:border-purple-500/30 transition-colors duration-500 overflow-hidden flex flex-col h-full">
        <div class="absolute -top-20 -right-20 w-40 h-40 bg-purple-500 opacity-0 group-hover:opacity-10 blur-[60px] rounded-full transition-opacity duration-500"></div>
        
        <div class="w-12 h-12 bg-purple-500/10 rounded-2xl flex items-center justify-center mb-6 text-purple-400 group-hover:scale-110 transition-transform duration-500">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
        </div>
        
        <h3 class="text-2xl font-bold text-white font-syne mb-3">Infraestructura Cloud</h3>
        <p class="text-gray-400 mb-6 text-sm flex-grow">Sistemas en la nube estables, escalables y sin los dolores de cabeza técnicos.</p>
        
        <ul class="space-y-3 mb-8">
          <li class="flex items-start text-sm text-gray-300">
            <svg class="w-5 h-5 text-purple-400 mr-2 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            Entornos que crecen al ritmo de tus ventas.
          </li>
          <li class="flex items-start text-sm text-gray-300">
            <svg class="w-5 h-5 text-purple-400 mr-2 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            Implementaciones SaaS sin fricción.
          </li>
          <li class="flex items-start text-sm text-gray-300">
            <svg class="w-5 h-5 text-purple-400 mr-2 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            Seguridad corporativa y respaldos 24/7.
          </li>
        </ul>
        
        <a href="#onboarding" class="text-purple-400 font-medium text-sm flex items-center hover:text-white transition-colors mt-auto">
          Modernizá tu estructura <span class="ml-2 group-hover:translate-x-1 transition-transform">→</span>
        </a>
      </div>

    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  
  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('astro:page-load', () => {
    gsap.fromTo('.soluciones-header', 
      { y: 30, opacity: 0 },
      { 
        y: 0, opacity: 1, duration: 1, ease: 'power3.out',
        scrollTrigger: {
          trigger: '.soluciones-header',
          start: 'top 80%',
        }
      }
    );

    gsap.fromTo('.solucion-card',
      { y: 50, opacity: 0 },
      {
        y: 0, opacity: 1, duration: 0.8, stagger: 0.2, ease: 'power3.out',
        scrollTrigger: {
          trigger: '.solucion-card',
          start: 'top 85%',
        }
      }
    );
  });
</script>
