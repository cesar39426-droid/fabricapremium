---
interface Props {
  brand?: string;
  tagline?: string;
  copy?: string;
  logoMark?: string;
  links?: Array<{ text: string; href: string }>;
  social?: Array<{ icon: string; href: string }>;
}

const {
  brand = "NubeN",
  tagline = "Cloud Growth Consultancy",
  copy = "© 2026 NubeN Cloud Growth Consultancy — Todos los derechos reservados.",
  logoMark = "N",
  links = [
    { text: "Servicios", href: "#servicios" },
    { text: "Proceso", href: "#proceso" },
    { text: "Resultados", href: "#resultados" },
    { text: "Contacto", href: "#contacto" },
  ],
  social = [
    { icon: "LN", href: "https://linkedin.com" },
    { icon: "IG", href: "https://instagram.com" },
    { icon: "X", href: "https://twitter.com" },
  ]
} = Astro.props;
---
<footer role="contentinfo">
  <div class="wrap footer-in">
    <div class="footer-brand">
      <div class="footer-logo-mark grad-text">{logoMark}</div>
      <div>
        <div class="footer-logo-txt">{brand}</div>
        <div class="footer-tagline">{tagline}</div>
      </div>
    </div>
    <nav aria-label="Footer links">
      <ul class="footer-links">
        {links.map((l) => (
          <li><a href={l.href}>{l.text}</a></li>
        ))}
      </ul>
    </nav>
  </div>
  <div class="wrap">
    <div class="footer-bottom">
      <p class="footer-copy">{copy}</p>
      <div class="footer-social">
        {social.map((s) => (
          <a href={s.href} target="_blank" rel="noopener" aria-label="Social Link">{s.icon}</a>
        ))}
      </div>
    </div>
  </div>
</footer>

<style>
  footer {
    padding: 100px 0 60px;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    background: var(--primary-blue);
  }

  .footer-in {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 60px;
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .footer-logo-mark {
    width: 56px;
    height: 56px;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 28px;
    color: var(--safety-orange);
  }

  .footer-logo-txt {
    font-weight: 800;
    font-size: 1.25rem;
    color: #fff;
    margin-bottom: 2px;
  }

  .footer-tagline {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.4);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .footer-links {
    display: flex;
    gap: 2.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-links a {
    font-size: 0.95rem;
    color: rgba(255,255,255,0.6);
    text-decoration: none;
    transition: color 0.3s;
  }

  .footer-links a:hover {
    color: var(--safety-orange);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 40px;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .footer-copy {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.4);
    margin: 0;
  }

  .footer-social {
    display: flex;
    gap: 20px;
  }

  .footer-social a {
    font-size: 0.8rem;
    font-weight: 800;
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 8px;
    transition: all 0.3s;
  }

  .footer-social a:hover {
    color: #fff;
    border-color: var(--safety-orange);
    background: rgba(249, 115, 22, 0.05);
  }

  @media (max-width: 768px) {
    .footer-in {
      flex-direction: column;
      gap: 3rem;
      text-align: center;
    }
    .footer-brand {
      flex-direction: column;
      gap: 1rem;
    }
    .footer-links {
      flex-direction: column;
      gap: 1.5rem;
      align-items: center;
    }
    .footer-bottom {
      flex-direction: column;
      gap: 2rem;
      text-align: center;
    }
  }
</style>
