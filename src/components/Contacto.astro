---
---
<section id="contacto" class="sec sec-alt">
  <div class="wrap cta-center">
    <div class="label-pill">Consulte ahora</div>
    <h2 class="sec-title cta-title">¿Listo para <span class="grad-text">escalar</span>?</h2>
    <p class="cta-sub">Dejanos tu email y un experto te contactará en menos de 24 horas.</p>
    
    <div class="cta-form">
      <div class="cta-group">
        <input type="email" id="cta-email" class="cta-input" placeholder="tu@email.com" aria-label="Email de contacto">
        <button id="cta-btn" class="btn btn-primary btn-cta">Explorar Solución →</button>
      </div>
      <p class="cta-notice">Al enviar, aceptás recibir solo información relevante para tu negocio.</p>
    </div>
  </div>
</section>

<style>
  .cta-center {
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
    padding: 3rem 0;
  }

  .cta-title {
    font-size: clamp(32px, 4vw, 64px);
    margin-bottom: 1.5rem;
  }

  .cta-sub {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.6);
    margin-bottom: 3.5rem;
  }

  .cta-form {
    max-width: 560px;
    margin: 0 auto;
  }

  .cta-group {
    display: flex;
    gap: 12px;
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.1);
    padding: 8px;
    border-radius: 20px;
    transition: all 0.3s;
  }

  .cta-group:focus-within {
    border-color: var(--safety-orange);
    background: rgba(255,255,255,0.04);
    box-shadow: 0 0 0 4px rgba(249, 115, 22, 0.1);
  }

  .cta-input {
    flex-grow: 1;
    background: transparent;
    border: none;
    color: #fff;
    padding: 0 20px;
    font-size: 1rem;
    outline: none;
  }

  .cta-input::placeholder {
    color: rgba(255,255,255,0.3);
  }

  .btn-cta {
    padding: 16px 28px;
    border-radius: 12px;
    font-size: 0.95rem;
  }

  .cta-notice {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.3);
    margin-top: 1.5rem;
  }

  @media (max-width: 768px) {
    .cta-group {
      flex-direction: column;
      background: transparent;
      border: none;
      padding: 0;
      gap: 16px;
    }
    .cta-input {
      background: rgba(255,255,255,0.02);
      border: 1px solid rgba(255,255,255,0.1);
      padding: 20px;
      border-radius: 16px;
    }
    .btn-cta {
      padding: 20px;
      border-radius: 16px;
    }
  }
</style>

<script>
  // Script para manejar el envío simulado y efectos
  document.addEventListener('astro:page-load', () => {
    const btn = document.getElementById('cta-btn');
    const input = document.getElementById('cta-email') as HTMLInputElement;

    btn?.addEventListener('click', () => {
      if (!input.value.includes('@')) {
        // @ts-ignore
        gsap.to(input, { x: [-10, 10, -5, 5, 0], duration: 0.3 });
        return;
      }
      
      const originalText = btn.textContent;
      btn.textContent = 'Enviando...';
      
      setTimeout(() => {
        btn.textContent = '¡Enviado!';
        // @ts-ignore
        gsap.to(btn, { backgroundColor: "#22c55e", duration: 0.5 });
        input.value = '';
        
        setTimeout(() => {
          btn.textContent = originalText;
          // @ts-ignore
          gsap.to(btn, { backgroundColor: "var(--safety-orange)", duration: 0.5 });
        }, 3000);
      }, 1500);
    });
  });
</script>
