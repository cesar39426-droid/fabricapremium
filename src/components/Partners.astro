---
const partners = [
  { name: "Tiendanube", icon: "📦" },
  { name: "Google Cloud", icon: "☁️" },
  { name: "AWS Partner", icon: "🖥️" },
  { name: "Mercado Pago", icon: "💳" },
  { name: "Meta Business", icon: "📱" },
  { name: "Bitrix24 Gold", icon: "⚙️" },
  { name: "Hostinger Pro", icon: "⚡" },
  { name: "Stripe Connect", icon: "🌍" },
];
---
<section class="partners-sec">
  <div class="wrap">
    <p class="partners-label">Empresas que confían en nuestra infraestructura digital</p>
    <div class="marquee" role="marquee">
      <div class="marquee-content">
        <!-- Contenido duplicado para el loop infinito -->
        {[...partners, ...partners].map((p) => (
          <div class="partner-card">
            <span class="partner-icon">{p.icon}</span>
            <span class="partner-name">{p.name}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .partners-sec {
    padding: 60px 0;
    overflow: hidden;
    background: rgba(15, 23, 42, 0.4);
    border-top: 1px solid rgba(255, 255, 255, 0.03);
    border-bottom: 1px solid rgba(255, 255, 255, 0.03);
  }

  .partners-label {
    text-align: center;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.3);
    margin-bottom: 40px;
    font-weight: 700;
  }

  .marquee {
    display: flex;
    overflow: hidden;
    user-select: none;
    mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
  }

  .marquee-content {
    flex-shrink: 0;
    display: flex;
    justify-content: space-around;
    min-width: 100%;
    gap: 60px;
    animation: scroll 30s linear infinite;
  }

  .partner-card {
    display: flex;
    align-items: center;
    gap: 12px;
    opacity: 0.5;
    transition: opacity 0.3s;
    filter: grayscale(1);
  }

  .partner-card:hover {
    opacity: 1;
    filter: grayscale(0);
  }

  .partner-icon {
    font-size: 1.5rem;
  }

  .partner-name {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 0.95rem;
    white-space: nowrap;
    color: #fff;
  }

  @keyframes scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  @media (max-width: 768px) {
    .marquee-content { gap: 40px; animation-duration: 20s; }
    .partner-name { font-size: 0.8rem; }
  }
</style>
