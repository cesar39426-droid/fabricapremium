---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import QuienesSomos from "../components/QuienesSomos.astro";
import Servicios from "../components/Servicios.astro";
import Proceso from "../components/Proceso.astro";
import Resultados from "../components/Resultados.astro";
import Diferencial from "../components/Diferencial.astro";
import Precios from "../components/Precios.astro";
import Contacto from "../components/Contacto.astro";
import Footer from "../components/Footer.astro";
import Whatsapp from "../components/Whatsapp.astro";
---

<Layout title="NubeN — Nueva Era Digital | Cloud Growth Consultancy">
  <Header />

  <main id="smooth-content">
    <Hero />
    <QuienesSomos />
    <Servicios />
    <Proceso />
    <Resultados />
    <Diferencial />
    <Precios />
    <Contacto />
  </main>

  <Footer />
  <Whatsapp />
</Layout>

<style>
  main {
    position: relative;
    z-index: 5;
    background: var(--dark);
  }
</style>

<script>
  // Global Interactions Orchestrator
  document.addEventListener('astro:page-load', () => {
    // @ts-ignore
    gsap.registerPlugin(ScrollTrigger);

    // Common reveals for all section titles
    // @ts-ignore
    gsap.utils.toArray('.sec-title').forEach((title: any) => {
      // @ts-ignore
      gsap.from(title, {
        scrollTrigger: {
          trigger: title,
          start: "top 90%",
          toggleActions: "play none none none"
        },
        y: 40,
        opacity: 0,
        duration: 1.2,
        ease: "power3.out"
      });
    });

    // Label pill reveals
    // @ts-ignore
    gsap.utils.toArray('.label-pill').forEach((pill: any) => {
      // @ts-ignore
      gsap.from(pill, {
        scrollTrigger: {
          trigger: pill,
          start: "top 92%",
        },
        scale: 0.8,
        opacity: 0,
        duration: 0.8,
        ease: "back.out(1.7)"
      });
    });
  });
</script>
